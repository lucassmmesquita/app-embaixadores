# ═══════════════════════════════════════════════════════════════
#  Admin Panel — Dockerfile DEV
#  Next.js dev server with hot-reload, code mounted via volume
# ═══════════════════════════════════════════════════════════════

FROM node:22-alpine

RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app

# Copy package files for dependency installation
COPY admin/package.json admin/.npmrc ./

# Install dependencies
RUN pnpm install

# Source code comes via volume mount — NOT copied here
# This enables hot-reload without rebuilding the container

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3002
ENV HOSTNAME="0.0.0.0"

EXPOSE 3002

# Dev server with hot-reload
CMD ["pnpm", "dev"]
