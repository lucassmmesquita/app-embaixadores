# ═══════════════════════════════════════════════════════════════
# Rede de Embaixadores — App Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ═══ API URL ═══
# Local (Docker):    http://localhost:8000
# Produção (Render): https://app-embaixadores.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# ═══ Supabase (Auth) ═══
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ═══ Google OAuth ═══
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id
