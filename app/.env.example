# ═══════════════════════════════════════════════════════════════
# Rede de Embaixadores — App Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# API URL (required for physical device builds)
EXPO_PUBLIC_API_URL=https://app-embaixadores.onrender.com

# Supabase (used for social auth)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (for social login)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id
