# ═══════════════════════════════════════════════════════════════
# Rede de Embaixadores — App Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ═══ API URL ═══
# Local (Docker):    http://localhost:8000
# Produção (Render): https://app-embaixadores.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# ═══ Supabase (Auth) ═══
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ═══ Google OAuth ═══
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id

# ═══ Firebase (Push Notifications) ═══
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_SENDER_ID=your-firebase-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key
